#!/usr/bin/with-contenv bashio
# If the web service exits, surface it and tell s6-overlay to bring the
# whole supervision tree down so the Supervisor notices and restarts the
# addon. Exit code 125 is s6-overlay's "stop everything" signal on both
# v2 and v3 — more portable than hardcoding /run/s6/basedir/bin/halt.

bashio::log.warning "Web service exited with status ${1:-unknown}; stopping container"
exec /run/s6/basedir/bin/halt 2>/dev/null || exit 125
