#!/usr/bin/with-contenv bashio
# Fix up /data ownership so the unprivileged 'app' user can read the
# Supervisor-mounted options.json and read/write the addon's own files.
#
# The Supervisor mounts /data/options.json root-owned. Without this fixup
# the 'app' user hits PermissionError at startup. See issue #14.
#
# Failures are logged but non-fatal — services.d/web/run falls back to
# running as root if the 'app' user isn't usable.

mkdir -p /data/polygonal_zones 2>/dev/null || \
    bashio::log.warning "Could not create /data/polygonal_zones"

if id app >/dev/null 2>&1; then
    chown -R app:app /data/polygonal_zones 2>/dev/null || \
        bashio::log.warning "chown /data/polygonal_zones failed (read-only mount?)"

    if [ -f /data/options.json ]; then
        # options.json may hold save_token (a password-type option), so we
        # keep it 0640 app:app. If chown fails (read-only mount, unexpected
        # FS), services.d/web/run detects that `app` can't read options.json
        # and falls back to running as root, which preserves readability
        # without making the secret world-readable.
        chown app:app /data/options.json 2>/dev/null || \
            bashio::log.warning "chown /data/options.json failed; web service will fall back to running as root"
    fi
else
    bashio::log.warning "'app' user not found; addon will run as root"
fi
